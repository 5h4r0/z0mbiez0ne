{
  "name": "backend",
  "type": "module",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "test": "npm test",
    "dev": "tsx --watch --env-file=.env ./src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env ./dist/index.js",
    "clean": "rm -rf dist",

    "db:create": "prisma migrate dev --schema=./src/models/schema.prisma --name init",
    "db:init": "prisma migrate dev --schema=./src/models/schema.prisma --name init --create-only",

    "db:deploy": "prisma migrate deploy --schema=./src/models/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./src/models/schema.prisma --name auto",
    "db:reset": "prisma migrate reset --force --schema=./src/models/schema.prisma",
    "db:generate": "prisma generate --schema=./src/models/schema.prisma",
    "db:studio": "prisma studio --schema=./src/models/schema.prisma",
    "db:seed": "tsx --env-file=.env ./src/models/seeding.ts"
  },
  "dependencies": {
    "express": "^5.1.0",
    "postgres": "^3.4.7",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@faker-js/faker": "^10.0.0",
    "@prisma/client": "^6.16.2",
    "@types/express": "^5.0.3",
    "prisma": "^6.16.2",
    "tsx": "^4.20.5"
  }
}
