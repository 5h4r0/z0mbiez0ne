{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Environment Settings */
    "module": "NodeNext",        // pour Node.js ESM
    "moduleResolution": "NodeNext",
    "target": "ES2022",          // output moderne mais compatible
    "lib": ["ESNext"],
    "types": ["node"],           // ajoute les types Node.js

    /* Other Outputs */
    "sourceMap": true,           // utile pour debug
    "declaration": true,         // génère les .d.ts (utile si tu publies une lib)
    "declarationMap": true,

    /* Stricter Typechecking Options */
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Recommended Options */
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
